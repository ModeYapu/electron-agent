# ========== Relay Server ==========
PORT=9300
NODE_ENV=production

# ========== Authentication ==========
# REQUIRED in production: at least 32 characters
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars

# Admin credentials for web console login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Agent connection token (used by Electron clients)
AGENT_TOKEN=change-this-agent-token

# Legacy admin token (for API access, backward compat)
ADMIN_TOKEN=change-this-admin-token

# ========== Logging ==========
LOG_LEVEL=info
