{
  "name": "electron-agent",
  "version": "0.1.0",
  "private": true,
  "description": "远程监控与操作平台 - 基于 Electron 的嵌入式 Agent 系统",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "verify": "tsc --noEmit",
    "build": "npm run build --workspaces --if-present",
    "test": "node --import tsx --test tests/*.test.ts",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "electron": "^42.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "body-parser": "^2.3.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^14.0.0",
    "ws": "^8.21.0"
  }
}
