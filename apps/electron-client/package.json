{
  "name": "@electron-agent/electron-client",
  "version": "0.2.2",
  "description": "Electron Agent Client — remote-controllable Electron shell for H5 pages",
  "author": "Nous Research",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsx watch src/main/index.ts",
    "build": "tsc && xcopy src\\renderer dist\\renderer\\ /E /Y /I && copy src\\main\\preload.js dist\\main\\ && copy config.default.json dist\\config.json && electron-builder",
    "verify": "tsc --noEmit"
  },
  "dependencies": {
    "@electron-agent/agent-core": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.9.0"
  },
  "build": {
    "appId": "com.electron-agent.client",
    "productName": "Electron Agent Client",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
